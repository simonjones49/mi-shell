// --- SYSTEM MONITOR WIDGET ---
PopupWindow {
  id: systemWidget
  anchor.window: mainBar
  anchor.rect.x: -600 // Moves it deep into the desktop area
  anchor.rect.y: 50
  implicitWidth: 150
  implicitHeight: 100
  visible: true // Always on

  // This is the "secret sauce" for widgets
  focusable: false

  Rectangle {
    anchors.fill: parent
    color: root.theme.bgBase
    opacity: 0.7 // Makes it look like a sleek overlay
    radius: 12
    border.width: 1
    border.color: root.theme.bgSurface

    Column {
      anchors.centerIn: parent
      spacing: 5
      Text {
        text: "SYSTEM STATUS";
        color: root.theme.accentPrimary;
        font.pixelSize: 10; font.bold: true;
        anchors.horizontalCenter: parent.horizontalCenter
      }
      Text {
        text: "CPU: " + SystemInfo.cpuUsage + "%";
        color: root.theme.textPrimary;
        font.pixelSize: 14
      }
      Text {
        text: "TEMP: " + root.currentTemp;
        color: root.theme.textPrimary;
        font.pixelSize: 14
      }
    }
  }
}
