#!/bin/bash

# --- CONFIGURATION ---
TARGET_PROCESSES=("cmus" "zenity" "wine" "wineserver" "andi2pc.py"
    "autobikecopy.sh" "bbc.sh" "cloud_backup.sh"
    "upload_videos_fixed.sh" "usb_backup.sh" "avidemux"
    "caffeine-flag.sh") # Added your ghost script
CHECK_INTERVAL=30
# ---------------------

send_notification() {
    notify-send "Mi-shell Power" "$1" -i "$2" -t 3000
}

while true; do
    MATCH_FOUND=false

    # Check for any active target processes
    for PROC in "${TARGET_PROCESSES[@]}"; do
        if pgrep -f "$PROC" | grep -v "$$" > /dev/null; then
            MATCH_FOUND=true
            break
        fi
    done

    if [[ "$MATCH_FOUND" == true ]]; then
        # If target is running, swayidle MUST be dead
        if pgrep -x "swayidle" > /dev/null; then
            pkill -9 swayidle
            # Kill any existing systemd-inhibit blocks to avoid duplicates
            pkill -f "systemd-inhibit.*Mi-shell"
            systemd-inhibit --what=idle:sleep --who="Mi-shell" --why="Target process running" sleep infinity &

            send_notification "Keep Awake: ENABLED" "keepassxc-unlocked"
        fi

    else
        # If no target is running, swayidle MUST be alive
        if ! pgrep -x "swayidle" > /dev/null; then
            # Clean up the systemd-inhibit block
            pkill -f "systemd-inhibit.*Mi-shell"

            # Restart swayidle using your config
            # (Best practice: call your run-swayidle.sh script here)
            swayidle -w \
                timeout 300 'niri msg action power-off-monitors' \
                timeout 360 'swaylock -f -c 000000' \
                timeout 900 'systemctl suspend' \
                resume 'niri msg action power-on-monitors' \
                before-sleep 'swaylock -f -c 000000' &

            send_notification "Keep Awake: DISABLED" "keepassxc-locked"
        fi
    fi

    sleep "$CHECK_INTERVAL"
done
